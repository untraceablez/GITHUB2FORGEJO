# GitHub Configuration
export GITHUB_USER=""
export GITHUB_TOKEN=""

# Forgejo Configuration (Defaults for setup_and_test.sh)
export FORGEJO_URL="http://localhost:3000"
export FORGEJO_USER="testuser"
export FORGEJO_TOKEN=""

# Migration Strategy (mirror/clone)
export STRATEGY="mirror"
export FORCE_SYNC="No"

# File-level sync (clone strategy only):
#   Yes => GitHub files overwrite differing Forgejo files
#   No  => differing GitHub files are added as <name>_copy.<ext>
export OVERWRITES="No"
